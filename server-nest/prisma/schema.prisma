generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Store {
  storeId        String  @id @map("store_id")
  templateId     String? @map("template_id")
  json           String?
  publishedJson  String? @map("published_json")
  subdomain      String? @unique

  @@map("stores")
}

model Template {
  id           String  @id
  category     String?
  folder       String?
  title        String?
  description  String?
  previewImage String? @map("preview_image")

  @@map("templates")
}
